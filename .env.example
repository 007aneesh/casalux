# =============================================================================
# CasaLux Environment Variables
# PRD Section 17
# Copy to .env and fill in values. NEVER commit .env to version control.
# =============================================================================

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://casalux:casalux_dev@localhost:5432/casalux"

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ─── Elasticsearch ────────────────────────────────────────────────────────────
ELASTICSEARCH_URL="http://localhost:9200"

# ─── Clerk Authentication ─────────────────────────────────────────────────────
CLERK_SECRET_KEY="sk_test_..."
# Web + Admin (public — can be in client code)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/"

# ─── Cloudinary Storage ───────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"
# Swap: cloudinary | s3 | r2 | local
STORAGE_ADAPTER="cloudinary"

# ─── Stripe Payments ──────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
# Swap: stripe | razorpay | paypal
PAYMENT_ADAPTER="stripe"

# ─── Resend Email ─────────────────────────────────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="CasaLux <noreply@casalux.com>"
# Swap: resend | sendgrid | ses
EMAIL_ADAPTER="resend"

# ─── Google Maps ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY="AIza..."

# ─── Platform Configuration ───────────────────────────────────────────────────
PLATFORM_SERVICE_FEE_PERCENT="12"
AUTO_APPROVE_HOSTS="false"
BOOKING_PAYMENT_WINDOW_SECONDS="900"      # 15 min Redis lock TTL
RECOMMENDATION_CACHE_TTL_SECONDS="900"    # 15 min

# ─── Bull Board (Queue Dashboard) ─────────────────────────────────────────────
BULL_BOARD_USERNAME="admin"
BULL_BOARD_PASSWORD="change_me_in_prod"

# ─── App URLs ─────────────────────────────────────────────────────────────────
API_PORT="3001"
NEXT_PUBLIC_API_URL="http://localhost:3001"
CORS_ORIGINS="http://localhost:3000,http://localhost:3002"
