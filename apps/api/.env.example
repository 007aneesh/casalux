# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# Comma-separated list of allowed CORS origins
# e.g. https://casalux.com,https://admin.casalux.com
CORS_ORIGINS=https://casalux.com,https://admin.casalux.com

# ── Database (Neon / Supabase / Railway Postgres) ─────────────────────────────
# Get from: neon.tech → project → connection string
# Must include ?sslmode=require for Neon
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# Get from: console.upstash.com → Redis → REST URL → copy "REDIS_URL"
# Used for: cache (CacheService) + BullMQ job queues
REDIS_URL=rediss://default:password@host:6380

# ── Elasticsearch (Elastic Cloud / Bonsai) ────────────────────────────────────
# Elastic Cloud:  https://user:pass@cluster.es.io:443
# Bonsai:         https://user:pass@host.bonsaisearch.net
ELASTICSEARCH_URL=https://user:password@host:443

# ── Clerk (Auth) ──────────────────────────────────────────────────────────────
# Get from: dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_live_...
# Get from: dashboard.clerk.com → Webhooks → Add endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_...

# ── Stripe (Payments) ─────────────────────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
# Get from: dashboard.stripe.com → Developers → Webhooks → endpoint signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Cloudinary (Image uploads) ────────────────────────────────────────────────
# Get from: console.cloudinary.com → Settings → Access Keys
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Resend (Transactional email) ──────────────────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=re_...

# ── Google Maps (Location autocomplete) ───────────────────────────────────────
# Get from: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_MAPS_API_KEY=AIza...

# ── Feature flags ─────────────────────────────────────────────────────────────
# Set to "true" to auto-approve host applications without manual review
AUTO_APPROVE_HOSTS=false

# Platform service fee percentage (default 12)
PLATFORM_SERVICE_FEE_PERCENT=12
