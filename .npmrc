engine-strict=true
# Always install devDependencies (needed for tsc, next, etc. on Vercel where NODE_ENV=production)
production=false
# Hoist all packages so React Native native module build scripts (Reanimated, etc.)
# can resolve their peers via require(). pnpm's default symlinked layout breaks
# `node -e "require.resolve('...')"` calls used by some build.gradle files.
node-linker=hoisted
